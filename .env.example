# Copia este archivo como ".env" en la raíz del proyecto (junto a package.json).
# Node carga estas variables automáticamente al iniciar gracias a dotenv (server.mjs).

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=pintagol

# Puerto HTTP del juego (opcional)
PORT=3333
